{
  "name": "dreamtoon-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dreamtoon-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dreamtoon-db --remote"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.1.30",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "nanoid": "^5.0.9",
    "stripe": "^17.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
